# VigilantNet Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# API key that clients must send in the X-API-Key header.
API_KEY=changeme

# Comma-separated list of IP addresses/subnets allowed as scan targets.
# The scanner will refuse to scan anything not in this list.
ALLOWED_TARGETS=127.0.0.1,localhost
